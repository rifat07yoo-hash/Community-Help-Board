    function calculateAndShowRating(userObj) {
        const element = document.getElementById("userRatingView");
        const ratings = userObj.ratings || [];
        if(ratings.length === 0) {
            element.innerHTML = "⭐️ No Reviews Yet";
        } else {
            let total = 0;
            ratings.forEach(r => total += r.score);
            const avg = (total / ratings.length).toFixed(1);
            element.innerHTML = `⭐ ${avg} (${ratings.length} reviews)`;
        }
    }

