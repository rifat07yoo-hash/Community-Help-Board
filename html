    function toggleCommentDropdown(e, postId, index) {
        e.stopPropagation();
        document.querySelectorAll('.comment-dropdown').forEach(d => {
            if (d.id !== `dropdown-${postId}-${index}`) d.classList.add('hidden');
        });
        document.getElementById(`dropdown-${postId}-${index}`).classList.toggle('hidden');
    }

    function editCommentTrigger(postId, index, text) {
        const newText = prompt("Edit your comment:", text);
        if (newText === null) return;
        const trimmed = newText.trim();
        if (!trimmed) {
            alert("Comment cannot be empty!");
            return;
        }

        const targetPost = requests.find(r => r.id === postId);
        const comments = targetPost.comments || [];
        if (comments[index]) {
            comments[index].text = trimmed;
            db.collection("requests").doc(postId).update({ comments: comments })
                .catch(err => alert("Error updating comment: " + err.message));
        }
    }

    function deleteComment(postId, index) {
        if (confirm("Are you sure you want to delete this comment?")) {
            const targetPost = requests.find(r => r.id === postId);
            const comments = targetPost.comments || [];
            comments.splice(index, 1);
            db.collection("requests").doc(postId).update({ comments: comments })
                .catch(err => alert("Error deleting comment: " + err.message));
        }
    }

