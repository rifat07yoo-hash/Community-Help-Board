            document.getElementById('signupArea').classList.add('active');
        }
        authMsgBox.classList.add("hidden");
    }

    function togglePassword(id) {
        const x = document.getElementById(id);
        const s = x.nextElementSibling;
        x.type = (x.type === "password") ? "text" : "password";
        s.innerText = (x.type === "password") ? "Show" : "Hide";
    }

    function checkStrength() {
        let p = document.getElementById("regPass").value;
        let b = document.getElementById("bar");
        let t = document.getElementById("strengthText");
        let s = 0;
        if(/[a-z]/.test(p)) s++; if(/[A-Z]/.test(p)) s++; if(/[0-9]/.test(p)) s++; if(/[^A-Za-z0-9]/.test(p)) s++;
        if(p.length === 0) { b.style.width = "0%"; t.innerText = "None"; t.className = "text-slate-500"; }
        else if(p.length < 6) { b.style.width = "20%"; b.style.background = "#ef4444"; t.innerText = "Very Weak"; t.className = "text-red-500"; }
        else if(s <= 2) { b.style.width = "60%"; b.style.background = "#f59e0b"; t.innerText = "Medium"; t.className = "text-amber-600"; }
        else { b.style.width = "100%"; b.style.background = "#10b981"; t.innerText = "Strong"; t.className = "text-emerald-600"; }
    }

    function signupUser(e) {
        e.preventDefault();
        const email = document.getElementById("regEmail").value.toLowerCase().trim();
        const pass = document.getElementById("regPass").value;
        const name = document.getElementById("regName").value.trim();
        const phone = document.getElementById("regPhone").value.trim();
        const locationStr = document.getElementById("regLocation").value.trim();
        const blood = document.getElementById("regBlood").value;
        const isVolunteer = document.getElementById("regVolunteer").checked;

        const secondaryApp = firebase.initializeApp(firebaseConfig, "SecondaryApp");
        
        secondaryApp.auth().createUserWithEmailAndPassword(email, pass)
            .then((userCredential) => {
                db.collection("users").doc(email).set({
                    name: name,
                    email: email,
                    phone: phone,
                    location: locationStr,
                    blood: blood,
                    isVolunteer: isVolunteer,
                    isAdmin: false,
                    isBanned: false,
                    ratings: [],
                    profileImage: ""
                }).then(() => {
                    showMsg("Registration Successful! Please sign in with your credentials.", "success");
                    secondaryApp.auth().signOut();
                    secondaryApp.delete();
                    setTimeout(() => showAuthTab('login'), 2500);
                });
            })
            .catch(error => {
                showMsg(error.message, "error");
                secondaryApp.delete();
            });
    }

    function loginUser(e) {
        e.preventDefault();
        const email = document.getElementById("loginId").value.toLowerCase().trim();
        const pass = document.getElementById("loginPass").value;

        auth.signInWithEmailAndPassword(email, pass)
            .then((userCredential) => {
                db.collection("users").doc(email).get().then((doc) => {
                    if (doc.exists) {
                        const uData = doc.data();
                        if (uData.isBanned === true) {
                            showMsg("⛔ Access Denied! Your account has been suspended by an Administrator.", "error");
                            auth.signOut();
                            return;
                        }
                        loggedInUser = uData;
                        startDashboard();
                    } else { showMsg("User data has been wiped!", "error"); }
                });
            })
            .catch(error => showMsg("Credentials invalid or unrecognized!", "error"));
    }

    function forgotPassword() {
        const email = document.getElementById("loginId").value.toLowerCase().trim();
        if (!email) {
            showMsg("Please enter your email address in the field above first!", "error");
            document.getElementById("loginId").focus();
            return;
        }
        auth.sendPasswordResetEmail(email)
            .then(() => {
                showMsg("Password reset link has been sent to your email inbox/spam folder!", "success");
            })
            .catch((error) => {
                if (error.code === 'auth/user-not-found') {
                    showMsg("No user found with this email address.", "error");
                } else {
                    showMsg(error.message, "error");
                }
