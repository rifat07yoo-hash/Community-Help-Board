    function submitComment(e, postId) {
        e.preventDefault();
        const inputField = e.target.querySelector('input');
        const text = inputField.value.trim();
        if(!text) return;

        const targetPost = requests.find(r => r.id === postId);
        const comments = targetPost.comments || [];

        comments.push({
            author: loggedInUser.name,
            email: loggedInUser.email,
            text: text,
            time: new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})
        });

        db.collection("requests").doc(postId).update({ comments: comments }).then(() => {
            inputField.value = "";
        }).catch(err => alert("Error posting comment: " + err.message));
    }

    document.getElementById("helpForm").addEventListener("submit", e => {
        e.preventDefault();
        const id = document.getElementById("editId").value;
        const postData = {
            name: loggedInUser.name,
            email: loggedInUser.email,
            userAvatar: loggedInUser.profileImage || "", 
            isVolunteer: loggedInUser.isVolunteer,
            category: document.getElementById("category").value,
            priority: document.getElementById("priority").value,
            location: document.getElementById("userLocation").value,
            contact: document.getElementById("contact").value,
            description: document.getElementById("description").value,
            targetQty: document.getElementById("targetQty").value || 1,
            collectedQty: document.getElementById("collectedQty").value || 0,
            timestamp: id === "-1" ? new Date().toLocaleString('en-US') : requests.find(r=>r.id===id).timestamp,
            resolved: id === "-1" ? false : requests.find(r=>r.id===id).resolved,
            messages: id === "-1" ? [] : requests.find(r=>r.id===id).messages,
            comments: id === "-1" ? [] : (requests.find(r=>r.id===id).comments || []),
            image: base64ImageString || (id !== "-1" ? requests.find(r=>r.id===id).image : ""),
            reports: id === "-1" ? [] : (requests.find(r=>r.id===id).reports || []),
            serverTimestamp: firebase.firestore.FieldValue.serverTimestamp()
        };
        
        if (id === "-1") {
            db.collection("requests").add(postData).then(() => {
                addNotification(`New Urgent Emergency in ${postData.location}!`);
            });
        } else {
            db.collection("requests").doc(id).set(postData).then(() => {
                addNotification(`Updates issued in ${postData.location}.`);
            });
        }
        resetForm();
    });

    function editPost(id) {
        const r = requests.find(req => req.id === id);
        document.getElementById("editId").value = id;
        document.getElementById("category").value = r.category;
        document.getElementById("priority").value = r.priority;
        document.getElementById("userLocation").value = r.location;
        document.getElementById("contact").value = r.contact;
        document.getElementById("description").value = r.description;
        document.getElementById("targetQty").value = r.targetQty || 1;
        document.getElementById("collectedQty").value = r.collectedQty || 0;
        
        if(r.image) {
            base64ImageString = r.image;
            document.getElementById("imagePreview").src = r.image;
            document.getElementById("imagePreviewContainer").classList.remove("hidden");
        }

        document.getElementById("formTitle").innerText = "Update Help Request Info";
        document.getElementById("submitBtn").innerText = "Apply Information Changes";
        document.getElementById("cancelEditBtn").classList.remove("hidden");
    }

    function resetForm() {
        document.getElementById("helpForm").reset();
        document.getElementById("editId").value = "-1";
        document.getElementById("formTitle").innerText = "Post Emergency Request";
        document.getElementById("submitBtn").innerText = "Post Help Request";
        document.getElementById("cancelEditBtn").classList.add("hidden");
        clearImageInput();
    }

    function toggleMap(btn, loc) {
        const container = btn.parentElement.nextElementSibling;
        if(container.innerHTML === "") {
            const mapUrl = "https://maps.google.com/maps?q=" + loc + "&t=&z=14&ie=UTF8&iwloc=&output=embed";
            container.innerHTML = `<iframe class="w-full h-44 rounded-2xl mt-3 border border-slate-200 shadow-inner" src="${mapUrl}"></iframe>`;
        }
        container.classList.toggle("hidden");
    }

    function navigateToLocation(loc) {
        const googleMapsUrl = "https://www.google.com/maps/search/?api=1&query=" + loc;
        window.open(googleMapsUrl, '_blank');
    }

    function sharePost(desc, loc) {
        const text = `Community Help Urgent Alert!\nRequirement: ${desc}\nArea details: ${decodeURIComponent(loc)}`;
        if (navigator.clipboard && window.isSecureContext) {
            navigator.clipboard.writeText(text)
                .then(() => alert("System Clipboard successfully synchronized with Emergency coordinates!"))
                .catch(() => useFallbackCopy(text));
        } else {
            useFallbackCopy(text);
        }
    }

    function useFallbackCopy(text) {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed"; 
        textArea.style.left = "-9999px";
        document.body.appendChild(textArea);
        textArea.focus();
        textArea.select();
        try {
            document.execCommand('copy');
            alert("System Clipboard successfully synchronized (Fallback)!");
        } catch (err) {
            alert("Unable to copy automatically.");
        }
        document.body.removeChild(textArea);
    }

    function openMessageModal(id) {
        activeChatPostId = id;
        const post = requests.find(r => r.id === id);
        if(!post) return;
        
        document.getElementById("messagePostId").value = id;
        document.getElementById("messagePostInfo").innerText = `${post.category.toUpperCase()} at ${post.location}`;
        
        listenToTypingState(id);
        
        const thread = document.getElementById("messageThread");
        thread.innerHTML = "";
        
        const secureMessages = post.messages || [];
        secureMessages.forEach((msg, idx) => {
            const isUserSender = msg.sender === loggedInUser.name;
            const isUserRecipient = msg.recipient === loggedInUser.name;
            if(isUserSender || isUserRecipient) {
                const messageAlign = isUserSender ? 'ml-auto bg-teal-600 text-white rounded-br-none' : 'mr-auto bg-slate-200 text-slate-800 rounded-bl-none';
                thread.innerHTML += `
                    <div class="p-3 rounded-2xl max-w-[85%] ${messageAlign} shadow-sm text-xs relative group transition-all">
                        <div class="flex justify-between items-center gap-4 mb-1">
                            <span class="font-extrabold text-[9px] opacity-60">${msg.sender}</span>
                            ${isUserSender ? `
                            <button onclick="deleteChatMessage('${id}', ${idx})" class="text-[10px] text-rose-300 hover:text-rose-100 font-bold transition ml-auto" title="Delete message">✕</button>
                            ` : ''}
                        </div>
                        <p class="break-words">${msg.text}</p>
                        <p class="text-[8px] text-right mt-1 opacity-40">${msg.timestamp.split(' ')[1] || ''} ${msg.read ? '✔✔' : '✔'}</p>
                    </div>`;
            }
        });
        
        document.getElementById("messageModal").classList.remove("hidden");
        document.getElementById("messageModal").classList.add("flex");
        
        let hasUpdated = false;
        secureMessages.forEach(m => {
            if(m.recipient === loggedInUser.name && !m.read) {
                m.read = true;
                hasUpdated = true;
            }
        });
        if(hasUpdated) {
            db.collection("requests").doc(id).update({ messages: secureMessages });
        }
    }

    // মেসেজ ডিলিট করার সিস্টেম (Secured Message Deletion Logic)
    function deleteChatMessage(postId, msgIndex) {
        if(confirm("Are you sure you want to delete this message?")) {
            const post = requests.find(r => r.id === postId);
            if(post && post.messages && post.messages[msgIndex]) {
                // Sender validation check before deletion
                if(post.messages[msgIndex].sender !== loggedInUser.name) {
                    alert("Unauthorized action! You can only delete your own messages.");
                    return;
                }
                
                post.messages.splice(msgIndex, 1); // remove from index array
                db.collection("requests").doc(postId).update({ messages: post.messages }).then(() => {
                    openMessageModal(postId); // Refresh current UI thread panel instantly
                }).catch(err => alert("Error updating chat tree: " + err.message));
            }
        }
    }

    function closeMessageModal() { 
        document.getElementById("messageModal").classList.add("hidden"); 
        if(activeChatPostId) {
            db.collection("requests").doc(activeChatPostId).collection("typing").doc(loggedInUser.email).delete();
            activeChatPostId = null;
        }
    }

    document.getElementById("messageForm").addEventListener("submit", e => {
        e.preventDefault();
        const id = document.getElementById("messagePostId").value;
        const msgText = document.getElementById("messageText").value.trim();
        const post = requests.find(r => r.id === id);
        
        if(!post.messages) post.messages = [];
        const recipientName = (loggedInUser.name === post.name) ? (post.messages.find(m=>m.sender !== loggedInUser.name)?.sender || 'Community Member') : post.name;

        post.messages.push({ 
            sender: loggedInUser.name, 
            recipient: recipientName,
            text: msgText, 
            timestamp: new Date().toLocaleString(), 
            read: false 
        });
        
        db.collection("requests").doc(id).update({ messages: post.messages }).then(() => {
            db.collection("requests").doc(id).collection("typing").doc(loggedInUser.email).delete();
            openMessageModal(id);
            document.getElementById("messageText").value = "";
        });
    });

    function sendTypingEvent() {
        if(!activeChatPostId) return;
        db.collection("requests").doc(activeChatPostId).collection("typing").doc(loggedInUser.email).set({
            name: loggedInUser.name,
            lastActive: firebase.firestore.FieldValue.serverTimestamp()
        });

        clearTimeout(typingTimer);
        typingTimer = setTimeout(() => {
            if(activeChatPostId) {
                db.collection("requests").doc(activeChatPostId).collection("typing").doc(loggedInUser.email).delete();
            }
        }, 3000);
    }

    function listenToTypingState(postId) {
        db.collection("requests").doc(postId).collection("typing").onSnapshot((snap) => {
            const typingIndicator = document.getElementById("chatTypingIndicator");
            let typingUsers = [];
            snap.forEach(doc => {
                if(doc.id !== loggedInUser.email) {
                    typingUsers.push(doc.data().name);
                }
            });
            if(typingUsers.length > 0) {
                typingIndicator.innerText = `${typingUsers.join(', ')} is typing...`;
            } else {
                typingIndicator.innerText = "";
            }
        });
    }

    function openInbox() {
        const inboxList = document.getElementById("inboxList");
        inboxList.innerHTML = "";
        
        const inboxPosts = requests.filter(r => {
            const secureMsgs = r.messages || [];
            return secureMsgs.some(m => m.sender === loggedInUser.name || m.recipient === loggedInUser.name);
        });
        
        if(inboxPosts.length === 0) { 
            inboxList.innerHTML = `<p class="text-center text-xs text-slate-500 p-6">No communication matches on file.</p>`; 
        }

        inboxPosts.forEach(post => {
            if (post.messages && post.messages.length > 0) {
                const unread = post.messages.some(m => m.recipient === loggedInUser.name && !m.read);
                inboxList.innerHTML += `
                    <div onclick="openMessageModal('${post.id}'); closeInbox();" class="p-4 rounded-2xl border cursor-pointer hover:bg-slate-100 transition-all ${unread ? 'bg-purple-50 border-purple-300' : 'bg-slate-50 border-slate-200'}">
                        <p class="font-bold text-teal-600 text-xs flex items-center justify-between">
                            <span>${post.name}</span>
                            ${unread ? '<span class="bg-rose-500 w-2.5 h-2.5 rounded-full inline-block shadow"></span>' : ''}
                        </p>
                        <p class="text-xs truncate text-slate-600 mt-1">${post.messages[post.messages.length-1].text}</p>
                    </div>`;
            }
        });
        document.getElementById("inboxModal").classList.remove("hidden");
        document.getElementById("inboxModal").classList.add("flex");
    }

    function closeInbox() { document.getElementById("inboxModal").classList.add("hidden"); }
    
    function openNotifications() {
        const list = document.getElementById("notifList");
        list.innerHTML = "";
        if(notifications.length === 0) { list.innerHTML = `<p class="text-center text-xs text-slate-500 p-6">Your Notification logs are fully cleared.</p>`; }
        notifications.forEach(n => {
            list.innerHTML += `
                <div class="p-3 bg-slate-50 border-l-4 border-teal-500 rounded-xl text-xs">
                    <p class="font-medium text-slate-700">${n.text}</p>
                    <span class="text-[9px] text-slate-400 block mt-1">${n.timestamp}</span>
                </div>`;
            if(!n.read) db.collection("notifications").doc(n.id).update({ read: true });
        });
        document.getElementById("notifModal").classList.remove("hidden");
        document.getElementById("notifModal").classList.add("flex");
    }

    function closeNotifications() { document.getElementById("notifModal").classList.add("hidden"); }
    
    function clearNotifications() {
        notifications.forEach(n => { db.collection("notifications").doc(n.id).delete(); });
        closeNotifications();
    }

    function updateNotifBadge() {
        let count = notifications.filter(n => !n.read).length;
        const badge = document.getElementById("notifBadge");
        if(count > 0) { badge.classList.remove("hidden"); badge.innerText = count; } else { badge.classList.add("hidden"); }
    }

    function toggleResolve(id) { 
        const post = requests.find(r => r.id === id);
        db.collection("requests").doc(id).update({ resolved: !post.resolved }).then(() => {
            addNotification(`Case status modified to resolved by ${post.name}.`);
        });
    }
    
    function deletePost(id) { if(confirm("Discard this post file permanently?")) { db.collection("requests").doc(id).delete(); } }
    
    function updateUnreadBadge() {
        let count = 0;
        requests.forEach(r => { 
            const secureMsgs = r.messages || [];
            count += secureMsgs.filter(m => m.recipient === loggedInUser.name && !m.read).length; 
        });
        const badge = document.getElementById("unreadBadge");
        if(count > 0) { badge.classList.remove("hidden"); badge.innerText = count; } else { badge.classList.add("hidden"); }
    }

    function reportPost(id) {
        const post = requests.find(r => r.id === id);
        let reports = post.reports || [];
        if(reports.includes(loggedInUser.email)) {
            alert("You have already reported this post once!");
            return;
        }
        if(confirm("Are you sure you want to flag and report this post?")) {
            reports.push(loggedInUser.email);
            db.collection("requests").doc(id).update({ reports: reports }).then(() => {
                alert("Post successfully reported.");
            });
        }
    }

    function triggerRatingModal(targetEmail) {
        if(targetEmail === loggedInUser.email) {
            alert("You cannot rate yourself!");
            return;
        }
        ratingTargetUserEmail = targetEmail;
        selectedRatingStars = 0;
        document.getElementById("ratingReviewText").value = "";
        setRatingValue(0);
        document.getElementById("ratingModal").classList.remove("hidden");
        document.getElementById("ratingModal").classList.add("flex");
    }

    function closeRatingModal() { document.getElementById("ratingModal").classList.add("hidden"); }

    function setRatingValue(val) {
        selectedRatingStars = val;
        const stars = document.getElementById("starRatingSelector").children;
        for (let i = 0; i < stars.length; i++) {
            if (i < val) {
                stars[i].innerText = "★";
                stars[i].classList.add("text-amber-500");
                stars[i].classList.remove("text-slate-300");
            } else {
                stars[i].innerText = "☆";
                stars[i].classList.add("text-slate-300");
                stars[i].classList.remove("text-amber-500");
            }
        }
    }

    function submitRating() {
        if(selectedRatingStars === 0) {
            alert("Please select at least 1 Star!");
            return;
        }
        const reviewText = document.getElementById("ratingReviewText").value.trim();
        db.collection("users").doc(ratingTargetUserEmail).get().then(doc => {
            if(doc.exists) {
                const targetUser = doc.data();
                let ratings = targetUser.ratings || [];
                const existingIndex = ratings.findIndex(r => r.by === loggedInUser.email);
                if(existingIndex > -1) {
                    ratings[existingIndex] = { by: loggedInUser.email, score: selectedRatingStars, review: reviewText };
                } else {
                    ratings.push({ by: loggedInUser.email, score: selectedRatingStars, review: reviewText });
                }
                db.collection("users").doc(ratingTargetUserEmail).update({ ratings: ratings }).then(() => {
                    alert("Your experience rating has been successfully saved!");
                    closeRatingModal();
                });
            }
        });
    }

    function listenToAdminPanel() {
        db.collection("requests").onSnapshot((snapshot) => {
            const list = document.getElementById("adminPostsList");
            document.getElementById("adminTotalPosts").innerText = snapshot.size;
            list.innerHTML = "";
            snapshot.forEach((doc) => {
                const r = doc.data();
                const reportCount = r.reports ? r.reports.length : 0;
                list.innerHTML += `
                    <div class="p-3.5 bg-slate-50 rounded-2xl border border-slate-200 flex flex-col sm:flex-row justify-between gap-3 text-xs">
                        <div class="truncate max-w-[70%]">
                            <p class="font-bold text-slate-800 flex items-center gap-1.5">
                                ${r.name} 
                                <span class="bg-rose-100 text-rose-700 px-2 py-0.5 rounded text-[9px] font-black uppercase">Reports: ${reportCount}</span>
                            </p>
                            <p class="text-[10px] text-slate-500 mt-1 truncate">${r.description}</p>
                        </div>
                        <div class="flex gap-2 self-center">
                            <button onclick="adminDeletePost('${doc.id}')" class="btn-glow bg-rose-600 hover:bg-rose-500 text-white px-3 py-1.5 rounded-xl font-bold transition">Delete Post</button>
                            ${reportCount > 0 ? `<button onclick="dismissReports('${doc.id}')" class="btn-glow bg-slate-200 hover:bg-slate-300 text-slate-700 px-3 py-1.5 rounded-xl font-bold transition">Clear Flags</button>` : ''}
                        </div>
                    </div>`;
            });
        });

        db.collection("users").onSnapshot((snapshot) => {
            const list = document.getElementById("adminUsersList");
            document.getElementById("adminTotalUsers").innerText = snapshot.size;
            list.innerHTML = "";
            snapshot.forEach((doc) => {
                const u = doc.data();
                list.innerHTML += `
                    <div class="p-3.5 bg-slate-50 rounded-2xl border border-slate-200 flex flex-col sm:flex-row justify-between gap-3 text-xs">
                        <div>
                            <p class="font-bold text-slate-800 flex items-center gap-1.5">
                                ${u.name} 
                                ${u.isAdmin ? '<span class="text-[9px] bg-teal-100 text-teal-700 border border-teal-300 px-1.5 py-0.5 rounded font-bold">Admin</span>' : ''}
                                ${u.isVolunteer ? '<span class="text-[9px] bg-amber-100 text-amber-700 border border-amber-300 px-1.5 py-0.5 rounded font-bold">Volunteer</span>' : ''}
                                ${u.isBanned ? '<span class="text-[9px] bg-rose-100 text-rose-700 border border-rose-300 px-1.5 py-0.5 rounded font-bold uppercase">Banned</span>' : ''}
                            </p>
                            <p class="text-[10px] text-slate-500 mt-1">✉️ ${u.email} | 📞 ${u.phone || 'N/A'}</p>
                        </div>
                        <div class="flex gap-2 self-center">
                            ${!u.isAdmin ? `
                                <button onclick="toggleBanUser('${u.email}', ${u.isBanned || false})" class="btn-glow ${u.isBanned ? 'bg-teal-600 text-white' : 'bg-rose-100 text-rose-700 hover:bg-rose-600 hover:text-white border border-rose-200'} px-2.5 py-1.5 rounded-xl font-bold transition">
                                    ${u.isBanned ? 'Unban User' : 'Ban User'}
                                </button>
                                <button onclick="adminDeleteUser('${u.email}')" class="btn-glow bg-rose-600 hover:bg-rose-500 text-white px-2.5 py-1.5 rounded-xl font-bold transition">Delete</button>
                            ` : ''}
                        </div>
                    </div>`;
            });
        });
    }

    function adminDeletePost(id) {
        if(confirm("🚨 CRITICAL ACTION: Remove this request post permanently?")) {
            db.collection("requests").doc(id).delete().then(() => alert("Post successfully wiped."));
        }
    }

    function dismissReports(id) {
        if(confirm("Dismiss all warnings and clear reported flags for this post?")) {
            db.collection("requests").doc(id).update({ reports: [] }).then(() => alert("Report flags cleared."));
        }
    }

    function toggleBanUser(email, currentBanStatus) {
        const actionText = currentBanStatus ? "Unban" : "Ban";
        if(confirm(`🚨 Are you sure you want to ${actionText} user ${email}?`)) {
            db.collection("users").doc(email).update({ isBanned: !currentBanStatus }).then(() => {
                alert(`User ${email} has been successfully ${actionText}ned.`);
            });
        }
    }

    function adminDeleteUser(email) {
        if(confirm(`⚠️ CRITICAL SECURITY WARNING: Wipe profile ${email}?`)) {
            db.collection("users").doc(email).delete().then(() => alert("Profile successfully purged."));
        }
    }

    auth.onAuthStateChanged((user) => {
        if (user) {
            db.collection("users").doc(user.email.toLowerCase()).get().then((doc) => {
                if (doc.exists) {
                    const uData = doc.data();
                    if (uData.isBanned === true) {
                        showMsg("⛔ Access Denied! Your account has been suspended by an Administrator.", "error");
                        auth.signOut();
                        navigateToPage('login');
                        return;
                    }
                    loggedInUser = uData;
                    startDashboard();
                } else {
                    navigateToPage('login');
                }
            });
        } else {
            navigateToPage('login');
        }
    });

    function escapeHtml(text) {
        return text
            .replace(/&/g, "&")
            .replace(/</g, "<")
            .replace(/>/g, ">")
            .replace(/"/g, '"')
            .replace(/'/g, "'");
    }
</script>
